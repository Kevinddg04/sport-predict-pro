# ============================================================
# SportPredict Pro — Variables de Entorno
# Copia este archivo como .env y completa los valores
# NUNCA commitees .env a Git
# ============================================================

# ---- Backend ----
APP_NAME="SportPredict Pro"
APP_VERSION="1.0.0"
DEBUG=true
SECRET_KEY=cambia_esto_por_un_secreto_largo_y_aleatorio

# ---- Base de Datos ----
# SQLite para desarrollo (no cambia nada)
DATABASE_URL=sqlite:///./data/sportpredict.db
# PostgreSQL para producción (descomenta):
# DATABASE_URL=postgresql://user:password@localhost:5432/sportpredict

# ---- CORS ----
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- ML Config ----
# Número de simulaciones Monte Carlo
MONTE_CARLO_SIMULATIONS=10000

# Ligas disponibles (football-data.co.uk codes)
# E0=Premier League, SP1=La Liga, D1=Bundesliga, I1=Serie A, F1=Ligue 1
LEAGUES=E0,SP1,D1

# Temporadas a descargar (formato: 2324 = temporada 2023/24)
SEASONS=2122,2223,2324

# ---- Frontend (Vite) ----
VITE_API_URL=http://localhost:8000
